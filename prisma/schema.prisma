generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model auth_user {
  user_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fname       String?
  lname       String?
  email       String   @unique
  password    String?
  is_verified Boolean? @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  task        task[]
}

model task {
  task_id     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String?
  description String?
  category    String?
  status      String?
  start_time  DateTime?  @db.Timetz(6)
  end_time    DateTime?  @db.Timetz(6)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @updatedAt
  user_id     String?    @db.Uuid
  auth_user   auth_user? @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}
